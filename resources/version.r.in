/* Auto-generated by CMake from the project VERSION file -- do not edit. */

/* 'vers' (1) is what the Finder reads for Get Info's "Version" line.
   majorVersion is a BCD byte; minorVersion packs minor (high nibble)
   and bugfix (low nibble). MACDOWN_VERSION components are constrained
   to single decimal digits by the templating in CMakeLists.txt. */
resource 'vers' (1, purgeable) {
    0x0@MACDOWN_VER_MAJOR@,
    0x@MACDOWN_VER_MINOR@@MACDOWN_VER_PATCH@,
    0x80,                /* stage: final */
    0x00,                /* non-release version */
    verUS,
    "@MACDOWN_VERSION@",
    "@MACDOWN_VERSION@, by Rockwell Schrock"
};

/* App signature -- the Finder reads creator 'MDED' here. */
type 'MDED' as 'STR ';
resource 'MDED' (0, "Owner resource") {
    "MacDown @MACDOWN_VERSION@"
};
